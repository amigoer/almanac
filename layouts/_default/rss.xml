{{- $sections := slice "posts" "travel" -}}
{{- $pages := where .Site.RegularPages "Section" "in" $sections -}}
{{- if not .IsHome -}}
  {{- $pages = .Pages -}}
{{- end -}}
{{- $title := cond .IsHome .Site.Title (printf "%s · %s" .Title .Site.Title) -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ $title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Description }}{{ . }}{{ else }}{{ .Site.Params.description | default .Site.Title }}{{ end }}</description>
    <generator>Hugo + amigoer</generator>
    <language>{{ .Site.LanguageCode | default "zh-cn" }}</language>
    <copyright>© {{ now.Year }} {{ .Site.Params.author | default .Site.Title }}</copyright>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{ range first 30 $pages.ByDate.Reverse }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <author>{{ $.Site.Params.email | default "i@amigoer.com" }} ({{ $.Site.Params.author | default $.Site.Title }})</author>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <description>{{ truncate 200 "…" (.Summary | plainify) | transform.XMLEscape | safeHTML }}</description>
      <content:encoded>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content:encoded>
      {{ range .Params.categories }}<category>{{ . }}</category>{{ end }}
    </item>
    {{ end }}
  </channel>
</rss>
